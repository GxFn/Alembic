{
  "name": "autosnippet",
  "displayName": "AutoSnippet",
  "description": "Knowledge-driven code snippets — search, insert, create, and audit directly in your editor",
  "version": "0.1.0",
  "publisher": "autosnippet",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "keywords": [
    "snippet",
    "knowledge",
    "code-search",
    "autosnippet"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autosnippet.search",
        "title": "AutoSnippet: Search Knowledge Base",
        "icon": "$(search)"
      },
      {
        "command": "autosnippet.create",
        "title": "AutoSnippet: Create Candidate from Selection"
      },
      {
        "command": "autosnippet.audit",
        "title": "AutoSnippet: Audit Current File"
      },
      {
        "command": "autosnippet.auditProject",
        "title": "AutoSnippet: Audit Entire Project"
      },
      {
        "command": "autosnippet.status",
        "title": "AutoSnippet: Show Connection Status"
      }
    ],
    "configuration": {
      "title": "AutoSnippet",
      "properties": {
        "autosnippet.serverPort": {
          "type": "number",
          "default": 3000,
          "description": "Port of the AutoSnippet API server (asd ui / asd start)"
        },
        "autosnippet.serverHost": {
          "type": "string",
          "default": "localhost",
          "description": "Host of the AutoSnippet API server"
        },
        "autosnippet.enableDirectiveDetection": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect // as:s, // as:c, // as:a directives on save"
        },
        "autosnippet.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens actions above AutoSnippet directives"
        },
        "autosnippet.enableGuardDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable Guard diagnostics on file save (shows violations as editor warnings)"
        },
        "autosnippet.tokenBudgetWarning": {
          "type": "number",
          "default": 20000,
          "description": "Token budget threshold for WARNING level context pressure hint"
        },
        "autosnippet.tokenBudgetCritical": {
          "type": "number",
          "default": 5000,
          "description": "Token budget threshold for CRITICAL level context pressure hint (triggers inline prime)"
        },
        "autosnippet.insertHighlightDuration": {
          "type": "number",
          "default": 2000,
          "description": "Duration (ms) to highlight inserted code"
        }
      }
    },
    "keybindings": [
      {
        "command": "autosnippet.search",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5"
      }
    ],
    "languageModelTools": [
      {
        "name": "autosnippet_taskgraph",
        "displayName": "AutoSnippet TaskGraph",
        "toolReferenceName": "autosnippet_taskgraph",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Manage AutoSnippet TaskGraph lifecycle. Operations: prime (restore session context), ready (get next tasks), claim (start task), close (finish task), create (add task), list (query tasks), show (task details), stats (project metrics), fail/defer (handle blockers), progress (update status), decompose (break into subtasks), blocked (view blocked tasks), dep_add/dep_tree (manage dependencies).",
        "icon": "$(database)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "operation": {
              "type": "string",
              "description": "Operation to perform",
              "enum": ["prime", "ready", "claim", "close", "create", "list", "show", "stats", "fail", "defer", "progress", "decompose", "blocked", "dep_add", "dep_tree"]
            },
            "id": {
              "type": "string",
              "description": "Task ID (for claim, close, show, fail, defer, progress, dep_tree)"
            },
            "title": {
              "type": "string",
              "description": "Task title (for create)"
            },
            "description": {
              "type": "string",
              "description": "Task description (for create, progress)"
            },
            "reason": {
              "type": "string",
              "description": "Reason (for close, fail, defer)"
            },
            "priority": {
              "type": "number",
              "description": "Priority 1-5, lower = higher (for create). Default: 2"
            },
            "parentId": {
              "type": "string",
              "description": "Parent task ID (for create, decompose)"
            },
            "limit": {
              "type": "number",
              "description": "Max results (for ready, list). Default: 5"
            },
            "status": {
              "type": "string",
              "description": "Filter by status (for list)",
              "enum": ["open", "in_progress", "closed", "deferred"]
            },
            "withKnowledge": {
              "type": "boolean",
              "description": "Include knowledge context (for ready). Default: true"
            },
            "taskId": {
              "type": "string",
              "description": "Source task ID (for dep_add)"
            },
            "dependsOn": {
              "type": "string",
              "description": "Target dependency task ID (for dep_add)"
            },
            "depType": {
              "type": "string",
              "description": "Dependency type (for dep_add). Default: blocks",
              "enum": ["blocks", "waits-for", "related"]
            },
            "children": {
              "type": "array",
              "description": "Subtask definitions (for decompose)",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                },
                "required": ["title"]
              }
            }
          },
          "required": ["operation"]
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
