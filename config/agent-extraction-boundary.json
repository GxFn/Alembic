        "reason": "Completion workflow lazily uses Agent memory/consolidation and should wait for Agent memory persistence migration."
      },
      {
        "path": "lib/workflows/capabilities/completion/WorkflowCompletionTypes.ts",
        "classification": "workflow-completion-agent-memory-type",
        "switchAfter": "phase-5",
        "replacement": "@alembic/agent/memory",
