{
  "version": 1,
  "plan": "docs/AlembicAgent/alembic-agent-extraction-boundary-plan-2026-05-17.md",
  "localAgentPolicy": {
    "status": "preserve-until-alembic-agent-runtime-replacement",
    "replacementPackage": "@alembic/agent",
    "replacementPhase": "phase-8-after-agent-phase-3-and-phase-4",
    "notes": [
      "Alembic keeps lib/agent/** until AlembicAgent has provider/tool runtime coverage and host entry tests.",
      "CLI, daemon, HTTP/API, Dashboard/native, IDE, Lark runtime, and product shell stay in Alembic."
    ]
  },
  "agentSourceNotes": [
    {
      "path": "lib/agent/profiles/definitions/remote.profile.ts",
      "boundary": "agent-profile-with-host-supplied-tools",
      "disposition": "keep-local-copy-until-runtime-switch",
      "reason": "remote-exec is an Agent profile, but its executable action space is intentionally empty here; host adapters decide which remote/system tools are exposed."
    },
    {
      "path": "lib/agent/profiles/definitions/signal.profile.ts",
      "boundary": "agent-profile-used-by-product-background-analysis",
      "disposition": "switch-call-site-after-agent-public-entrypoint",
      "reason": "signal-analysis is a generic Agent run profile, while SignalCollector remains an Alembic daemon/product-shell service."
    },
    {
      "path": "lib/tools/adapters/MacSystemAdapter.ts",
      "boundary": "alembic-main-platform-adapter",
      "disposition": "do-not-move-in-phase-4-without-host-adapter-contract",
      "reason": "macOS execution depends on local native resources, TCC policy, and artifact materialization owned by the Alembic product shell."
    },
    {
      "path": "lib/tools/adapters/MacSystemCapabilities.ts",
      "boundary": "alembic-main-platform-capabilities",
      "disposition": "do-not-move-in-phase-4-without-host-adapter-contract",
      "reason": "macOS capability manifests expose host platform permissions and native screenshot behavior, not portable Agent tool contracts."
    }
  ],
  "agentImportRules": {
    "scanRoots": ["lib", "bin"],
    "ignoredPathPrefixes": ["lib/agent/"],
    "allowedCallSites": [
      {
        "path": "lib/external/lark/LarkTransport.ts",
        "classification": "host-transport-agent-service",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "Lark remains a host transport and should call the future Agent service facade instead of owning runtime internals."
      },
      {
        "path": "lib/http/routes/ai.ts",
        "classification": "host-http-agent-route",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "HTTP route owns request/session presentation while delegating run execution to AgentService."
      },
      {
        "path": "lib/http/routes/extract.ts",
        "classification": "host-http-agent-route",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "HTTP extraction route is an Alembic API boundary around Agent task execution."
      },
      {
        "path": "lib/http/routes/recipes.ts",
        "classification": "host-http-agent-route",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "Recipe relation discovery should later call the Agent package facade from the route boundary."
      },
      {
        "path": "lib/injection/modules/AgentModule.ts",
        "classification": "host-dependency-injection-composition",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent plus Alembic host adapters",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "The module composes Agent runtime classes with Alembic-owned Dashboard, Skill, Mac, Terminal, Workflow, and MCP adapters."
      },
      {
        "path": "lib/service/module/ModuleService.ts",
        "classification": "product-service-agent-task",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "Module scanning remains an Alembic service and should later delegate scan agent tasks to the Agent package."
      },
      {
        "path": "lib/service/skills/SignalCollector.ts",
        "classification": "product-background-agent-task",
        "switchAfter": "phase-8",
        "replacement": "@alembic/agent/service",
        "expectedSpecifiers": ["#agent/service/index.js"],
        "reason": "SignalCollector is an Alembic daemon feature that invokes the signal-analysis Agent profile."
      },
      {
        "path": "lib/tools/v2/capabilities/CapabilityV2.ts",
        "classification": "tool-system-agent-base-class",
        "switchAfter": "phase-4",
        "replacement": "@alembic/agent/tools",
        "expectedSpecifiers": ["#agent/capabilities/Capability.js"],
        "reason": "The V2 tool capability base currently inherits the Agent Capability type and belongs to the common tool-system migration set."
      },
      {
        "path": "lib/workflows/capabilities/completion/CompletionSteps.ts",
        "classification": "workflow-completion-agent-memory",
        "switchAfter": "phase-5",
        "replacement": "@alembic/agent/memory",
        "expectedSpecifiers": [
          "#agent/domain/EpisodicConsolidator.js",
          "#agent/memory/MemoryEmbeddingStore.js",
          "#agent/memory/PersistentMemory.js"
