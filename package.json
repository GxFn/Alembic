{
  "name": "alembic-ai",
  "version": "0.2.0",
  "description": "Alembic — Auto Source Distill. Distill project knowledge from source code into structured recipes for humans and AI agents.",
  "type": "module",
  "main": "dist/lib/Bootstrap.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#shared/*": {
      "alembic-dev": "./lib/shared/*",
      "default": "./dist/lib/shared/*"
    },
    "#infra/*": {
      "alembic-dev": "./lib/infrastructure/*",
      "default": "./dist/lib/infrastructure/*"
    },
    "#service/*": {
      "alembic-dev": "./lib/service/*",
      "default": "./dist/lib/service/*"
    },
    "#inject/*": {
      "alembic-dev": "./lib/injection/*",
      "default": "./dist/lib/injection/*"
    },
    "#governance/*": {
      "alembic-dev": "./lib/governance/*",
      "default": "./dist/lib/governance/*"
    },
    "#platform/*": {
      "alembic-dev": "./lib/platform/*",
      "default": "./dist/lib/platform/*"
    },
    "#types/*": {
      "alembic-dev": "./lib/types/*",
      "default": "./dist/lib/types/*"
    },
    "#http/*": {
      "alembic-dev": "./lib/http/*",
      "default": "./dist/lib/http/*"
    },
    "#tools/*": {
      "alembic-dev": "./lib/tools/*",
      "default": "./dist/lib/tools/*"
    },
    "#sandbox/*": {
      "alembic-dev": "./lib/sandbox/*",
      "default": "./dist/lib/sandbox/*"
    },
    "#recipe-pipeline/*": {
      "alembic-dev": "./lib/recipe-pipeline/*",
      "default": "./dist/lib/recipe-pipeline/*"
    }
  },
  "scripts": {
    "build": "npm run build:core && npm run clean:dist && tsc",
    "build:self": "npm run clean:dist && tsc && npm run postbuild",
    "build:check": "npm run build:core && tsc --noEmit",
    "build:core": "node scripts/core-source-command.mjs build",
    "clean:dist": "node scripts/clean-dist.mjs",
    "postbuild": "node scripts/postbuild.mjs",
    "verify:context-api": "node dist/scripts/verify-context-api.js",
    "generate:dashboard-types": "node dist/scripts/generate-dashboard-types.js --write",
    "check:dashboard-types-drift": "node dist/scripts/generate-dashboard-types.js --check",
    "build:dashboard": "node scripts/build-dashboard.mjs",
    "start": "node dist/bin/cli.js start",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:codex": "vitest run --config vitest.unit.codex.config.ts",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --coverage",
    "test:coverage:all": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke:multi-project-control": "node scripts/smoke-multi-project-control.mjs",
    "dev:link": "node scripts/dev-link.mjs",
    "dev:verify": "node scripts/dev-link.mjs --verify-only",
    "release:package-guard": "node scripts/verify-release-package-boundary.mjs",
    "release:staging:prepare": "node scripts/prepare-publish-staging.mjs",
    "release:staging:pack": "node scripts/prepare-publish-staging.mjs --pack-dry-run",
    "release:check": "npm run build && node dist/scripts/release.js check",
    "release:patch": "npm run build && node dist/scripts/release.js patch",
    "release:minor": "npm run build && node dist/scripts/release.js minor",
    "release:major": "npm run build && node dist/scripts/release.js major",
    "cli": "node dist/bin/cli.js",
    "lint": "biome check lib/ bin/ config/ scripts/",
    "lint:fix": "biome check --fix lib/ bin/ config/ scripts/",
    "lint:agent-extraction-boundary": "node scripts/lint-agent-extraction-boundary.mjs",
    "lint:core-import-boundary": "node scripts/core-source-command.mjs lint-consumer-imports",
    "lint:consumer-core-imports": "node scripts/core-source-command.mjs lint-consumer-imports",
    "lint:repo-boundary": "node scripts/lint-repo-boundary.mjs",
    "check:space-edges": "node scripts/check-space-edges.mjs",
    "lint:layer-contract": "node scripts/lint-layer-contract.mjs",
    "lint:doctrine": "node scripts/lint-doctrine.mjs",
    "lint:naming": "node scripts/lint-naming.mjs",
    "check:shared-asset-drift": "node scripts/check-shared-asset-drift.mjs",
    "format": "biome format --write lib/ bin/ config/ scripts/",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run lint:repo-boundary && npm run check:space-edges && npm run lint:layer-contract && npm run lint:doctrine && npm run lint:naming && npm run lint:agent-extraction-boundary && npm run lint:core-import-boundary && npm run lint:consumer-core-imports && npm run test:unit && npm run test:integration && npm run test:coverage && npm run check:shared-asset-drift && npm run lint:retired-symbols && npm run lint:ring-direction",
    "prepare": "husky",
    "lint:retired-symbols": "node ../AlembicCore/scripts/lint-retired-symbols.mjs . --dirs=lib,bin,test",
    "lint:ring-direction": "node ../AlembicCore/scripts/lint-ring-direction.mjs ."
  },
  "author": "gaoxuefeng",
  "license": "MIT",
  "bin": {
    "alembic": "dist/bin/cli.js"
  },
  "keywords": [
    "knowledge-base",
    "ai",
    "ai-agent",
    "code-review",
    "guard",
    "ast",
    "tree-sitter",
    "typescript",
    "javascript",
    "python",
    "swift",
    "rust",
    "kotlin",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/GxFn/Alembic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GxFn/Alembic.git"
  },
  "dependencies": {
    "@alembic/agent": "file:../AlembicAgent",
    "@alembic/core": "file:../AlembicCore",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "minimist": "^1.2.8",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "socket.io": "^4.8.3",
    "undici": "^7.22.0",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.6",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "bugs": {
    "url": "https://github.com/GxFn/Alembic/issues"
  },
  "files": [
    "dist",
    "config",
    "scripts/clean-dist.mjs",
    "scripts/postbuild.mjs",
    "skills",
    "templates",
    "dashboard/dist",
    "resources/openChrome.applescript"
  ],
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.19.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "diff": "^8.0.3",
    "glob": "^11.0.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "biome check --fix --no-errors-on-unmatched --diagnostic-level=error",
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
