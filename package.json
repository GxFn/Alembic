{
  "name": "autosnippet",
  "version": "3.2.9",
  "description": "Extract code patterns into a knowledge base for AI coding assistants",
  "type": "module",
  "main": "lib/bootstrap.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall-safe.js",
    "prepublishOnly": "npm run build:dashboard && node scripts/build-native-ui.js",
    "build:native-ui": "swiftc resources/native-ui/main.swift resources/native-ui/combined-window.swift -o resources/native-ui/native-ui -framework AppKit",
    "build:screenshot": "swiftc -O -framework ScreenCaptureKit -framework AppKit resources/native-ui/screenshot.swift -o resources/native-ui/screenshot",
    "install:cursor-skill": "node scripts/install-cursor-skill.js",
    "install:cursor-skill:mcp": "node scripts/install-cursor-skill.js --mcp",
    "install:vscode-copilot": "node scripts/install-vscode-copilot.js",
    "install:full": "node scripts/install-full.js",
    "verify:context-api": "node scripts/verify-context-api.js",
    "setup:mcp": "node scripts/setup-mcp-config.js --editor vscode && node scripts/setup-mcp-config.js --editor cursor",
    "build:dashboard": "cd dashboard && npm run build",
    "dashboard": "node bin/cli.js ui",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "npm test -- test/unit",
    "test:integration": "npm test -- test/integration",
    "test:e2e": "npm test -- test/e2e",
    "test:coverage": "npm test -- --coverage",
    "dev:link": "npm install -g .",
    "dev:verify": "which asd && asd -v",
    "release:check": "node scripts/release.js check",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "cli": "node bin/cli.js",
    "mcp": "node bin/mcp-server.js",
    "init:snippets": "node scripts/init-snippets.js init",
    "list:snippets": "node scripts/init-snippets.js list",
    "remove:snippets": "node scripts/init-snippets.js remove",
    "diagnose:mcp": "node scripts/diagnose-mcp.js"
  },
  "author": "gaoxuefeng",
  "license": "MIT",
  "bin": {
    "asd": "bin/cli.js",
    "asd-mcp": "bin/mcp-server.js"
  },
  "keywords": [
    "snippet",
    "code-snippet",
    "knowledge-base",
    "ai",
    "mcp",
    "copilot",
    "cursor",
    "code-review",
    "guard",
    "ast",
    "tree-sitter",
    "xcode",
    "ios",
    "swift",
    "typescript",
    "javascript",
    "python",
    "rust",
    "kotlin",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/GxFn/AutoSnippet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GxFn/AutoSnippet.git"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@protobufjs/aspromise": "^1.1.2",
    "@protobufjs/base64": "^1.1.2",
    "@protobufjs/codegen": "^2.0.4",
    "@protobufjs/eventemitter": "^1.1.0",
    "@protobufjs/fetch": "^1.1.0",
    "@protobufjs/float": "^1.0.2",
    "@protobufjs/inquire": "^1.1.0",
    "@protobufjs/path": "^1.1.2",
    "@protobufjs/pool": "^1.1.0",
    "@protobufjs/utf8": "^1.1.0",
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.6.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.5",
    "open": "^8.0.4",
    "ora": "^8.0.1",
    "socket.io": "^4.8.1",
    "undici": "^6.23.0",
    "uuid": "^9.0.1",
    "web-tree-sitter": "^0.25.0",
    "winston": "^3.11.0"
  },
  "bugs": {
    "url": "https://github.com/GxFn/AutoSnippet/issues"
  },
  "files": [
    "bin",
    "lib",
    "config",
    "scripts",
    "skills",
    "templates",
    "dashboard/dist",
    "template.json",
    "resources/native-ui/main.swift",
    "resources/native-ui/combined-window.swift",
    "resources/native-ui/native-ui",
    "resources/native-ui/screenshot.swift",
    "resources/native-ui/screenshot",
    "resources/native-ui/README.md",
    "resources/openChrome.applescript",
    "resources/grammars"
  ],
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@types/node": "^20.10.6",
    "jest": "^30.2.0",
    "nodemon": "^3.1.13",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "diff": "^8.0.3",
    "glob": "^11.0.0"
  }
}
