{
  "name": "autosnippet",
  "version": "3.2.10",
  "description": "Extract code patterns into a knowledge base for AI coding assistants",
  "type": "module",
  "main": "dist/lib/bootstrap.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "postbuild": "node scripts/postbuild.mjs",
    "postinstall": "node scripts/postinstall-safe.js",
    "prepublishOnly": "npm run build && npm run build:dashboard && node scripts/build-native-ui.js",
    "build:native-ui": "swiftc resources/native-ui/main.swift resources/native-ui/combined-window.swift -o resources/native-ui/native-ui -framework AppKit",
    "build:screenshot": "swiftc -O -framework ScreenCaptureKit -framework AppKit resources/native-ui/screenshot.swift -o resources/native-ui/screenshot",
    "install:cursor-skill": "node dist/scripts/install-cursor-skill.js",
    "install:cursor-skill:mcp": "node dist/scripts/install-cursor-skill.js --mcp",
    "install:vscode-copilot": "node dist/scripts/install-vscode-copilot.js",
    "install:full": "node dist/scripts/install-full.js",
    "verify:context-api": "node dist/scripts/verify-context-api.js",
    "setup:mcp": "node dist/scripts/setup-mcp-config.js --editor vscode && node dist/scripts/setup-mcp-config.js --editor cursor",
    "build:dashboard": "cd dashboard && npm run build",
    "dashboard": "node dist/bin/cli.js ui",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev:link": "npm run build && npm install -g .",
    "dev:verify": "which asd && asd -v",
    "release:check": "node dist/scripts/release.js check",
    "release:patch": "node dist/scripts/release.js patch",
    "release:minor": "node dist/scripts/release.js minor",
    "release:major": "node dist/scripts/release.js major",
    "cli": "node dist/bin/cli.js",
    "mcp": "node dist/bin/mcp-server.js",
    "init:snippets": "node dist/scripts/init-snippets.js init",
    "list:snippets": "node dist/scripts/init-snippets.js list",
    "remove:snippets": "node dist/scripts/init-snippets.js remove",
    "diagnose:mcp": "node dist/scripts/diagnose-mcp.js",
    "lint": "biome check lib/ bin/ config/ scripts/",
    "lint:fix": "biome check --fix lib/ bin/ config/ scripts/",
    "format": "biome format --write lib/ bin/ config/ scripts/",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json || true",
    "check": "npm run typecheck && npm run lint",
    "prepare": "husky"
  },
  "author": "gaoxuefeng",
  "license": "MIT",
  "bin": {
    "asd": "dist/bin/cli.js",
    "asd-mcp": "dist/bin/mcp-server.js"
  },
  "keywords": [
    "snippet",
    "code-snippet",
    "knowledge-base",
    "ai",
    "mcp",
    "copilot",
    "cursor",
    "code-review",
    "guard",
    "ast",
    "tree-sitter",
    "xcode",
    "ios",
    "swift",
    "typescript",
    "javascript",
    "python",
    "rust",
    "kotlin",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/GxFn/AutoSnippet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GxFn/AutoSnippet.git"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@protobufjs/aspromise": "^1.1.2",
    "@protobufjs/base64": "^1.1.2",
    "@protobufjs/codegen": "^2.0.4",
    "@protobufjs/eventemitter": "^1.1.0",
    "@protobufjs/fetch": "^1.1.0",
    "@protobufjs/float": "^1.0.2",
    "@protobufjs/inquire": "^1.1.0",
    "@protobufjs/path": "^1.1.2",
    "@protobufjs/pool": "^1.1.0",
    "@protobufjs/utf8": "^1.1.0",
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.6.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.5",
    "open": "^8.0.4",
    "ora": "^8.0.1",
    "socket.io": "^4.8.1",
    "undici": "^6.23.0",
    "uuid": "^9.0.1",
    "web-tree-sitter": "^0.25.0",
    "winston": "^3.11.0"
  },
  "bugs": {
    "url": "https://github.com/GxFn/AutoSnippet/issues"
  },
  "files": [
    "dist",
    "config",
    "scripts/postinstall-safe.js",
    "scripts/postbuild.mjs",
    "skills",
    "templates",
    "dashboard/dist",
    "template.json",
    "resources/native-ui/main.swift",
    "resources/native-ui/combined-window.swift",
    "resources/native-ui/native-ui",
    "resources/native-ui/screenshot.swift",
    "resources/native-ui/screenshot",
    "resources/native-ui/README.md",
    "resources/openChrome.applescript",
    "resources/grammars"
  ],
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "nodemon": "^3.1.13",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "diff": "^8.0.3",
    "glob": "^11.0.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "biome check --fix --no-errors-on-unmatched --diagnostic-level=error",
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
