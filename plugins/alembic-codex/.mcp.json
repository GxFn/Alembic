{
  "mcpServers": {
    "alembic": {
      "command": "npx",
      "args": ["-y", "--prefix", "/tmp", "--package", "alembic-ai@0.1.0", "alembic-codex-mcp"],
      "env": {
        "ALEMBIC_CHANNEL_ID": "codex",
        "ALEMBIC_CODEX_ENABLE_ADMIN": "0",
        "ALEMBIC_CODEX_MCP_MODE": "1",
        "ALEMBIC_MCP_MODE": "1",
        "ALEMBIC_MCP_TIER": "agent"
      }
    }
  }
}
