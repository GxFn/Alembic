# AutoSnippet 环境变量配置文件示例 (v2.6.0)
#
# 使用方式：
#   1. 将本文件复制到项目根目录，重命名为 .env
#   2. 填写 AI Provider 的 API Key（至少填一个）
#   3. 可选：按需修改其他配置项
#
# 配置生效范围：asd ui、asd create、asd ais、asd watch、asd embed、asd search -m 等

# =============================================================================
# --- 0. 环境模式 ---
# =============================================================================
# 开发模式: development + http://localhost:3100
# 线上模式: production  + 你的生产 API 地址
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:3100

# =============================================================================
# --- 1. AI 提供商配置 ---
# =============================================================================
# 当前使用的 AI 提供商
# 可选值: google, openai, deepseek, claude, ollama, mock
#   google   → ASD_GOOGLE_API_KEY
#   openai   → ASD_OPENAI_API_KEY（含兼容接口）
#   deepseek → ASD_DEEPSEEK_API_KEY
#   claude   → ASD_CLAUDE_API_KEY
#   ollama   → 本地 Ollama，一般不需 Key
#   mock     → 模拟模式，用于测试
ASD_AI_PROVIDER=google

# 模型名称示例：
#   google:   gemini-3-flash-preview, gemini-2.5-flash, gemini-2.0-flash
#   openai:   gpt-5.4, gpt-5.4-mini, gpt-4o
#   deepseek: deepseek-chat, deepseek-coder
#   claude:   claude-sonnet-4-20250514, claude-opus-4-6-20260301
#   ollama:   llama3, qwen2, mistral
ASD_AI_MODEL=gemini-3-flash-preview

# 各提供商 API Key（只填当前使用的即可）
ASD_GOOGLE_API_KEY=
ASD_OPENAI_API_KEY=
ASD_DEEPSEEK_API_KEY=
ASD_CLAUDE_API_KEY=

# 统一 AI 代理（优先于 HTTPS_PROXY / ALL_PROXY）
# ASD_AI_PROXY=http://127.0.0.1:7890

# 自定义 API 地址（可选，适用于自建代理或本地服务不在默认端口）
# ASD_OPENAI_BASE_URL=https://api.openai.com/v1
# ASD_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ASD_CLAUDE_BASE_URL=https://api.anthropic.com/v1
# ASD_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# =============================================================================
# --- 2. 日志与调试 ---
# =============================================================================
# 日志级别: debug, info, warn, error（默认 info）
# ASD_LOG_LEVEL=info

# MCP 模式（MCP Server 启动时自动设置，禁用 console transport）
# ASD_MCP_MODE=0

# 详细调试输出（FileWatcher / SaveEventFilter / HeaderHandler / OpenBrowser）
# ASD_DEBUG=0

# =============================================================================
# --- 3. Dashboard 与认证 ---
# =============================================================================
# 设为 true 启用登录页；默认不启用
VITE_AUTH_ENABLED=false
# ASD_AUTH_ENABLED=false
ASD_AUTH_USERNAME=admin
ASD_AUTH_PASSWORD=autosnippet
# ASD_AUTH_SECRET=           # JWT 签名密钥，未设置则自动生成随机值

# Dashboard 地址（FileWatcher 向 Dashboard 发送通知时使用）
# ASD_DASHBOARD_URL=http://localhost:3000

# =============================================================================
# --- 4. 监听与文件系统 ---
# =============================================================================
# 文件监听轮询模式（NFS/网络盘/部分虚拟机可改为 true）
ASD_WATCH_POLLING=false

# Xcode Code Snippets 存储路径（留空使用默认 ~/Library/Developer/Xcode/UserData/CodeSnippets）
ASD_SNIPPETS_PATH=

# AutoSnippet 缓存目录（一般无需修改）
ASD_CACHE_PATH=

# SPM 依赖自动修复模式: off(默认) | suggest | fix
ASD_FIX_SPM_DEPS_MODE=

# 保存事件过滤（设为 0 禁用）
# ASD_SAVE_FILTER=1

# Xcode 前台检测（设为 0 禁用）
# ASD_XCODE_FOCUS_CHECK=1

# 自定义触发符号
# ASD_TRIGGER_SYMBOL=

# =============================================================================
# --- 5. SignalCollector 信号收集 ---
# =============================================================================
# 信号收集模式: off | suggest | auto（默认 auto）
#   off     — 关闭信号收集
#   suggest — 仅推荐 Skill，不自动创建
#   auto    — AI 分析后自动创建 Skill
ASD_SIGNAL_MODE=auto
# 初始采集间隔（毫秒，默认 3600000 = 1 小时，AI 会动态调整）
# ASD_SIGNAL_INTERVAL=3600000

# =============================================================================
# --- 6. MCP Server ---
# =============================================================================
# MCP 模式下的目标项目目录（默认为当前工作目录）
# ASD_PROJECT_DIR=

# =============================================================================
# --- 7. 浏览器与 UI ---
# =============================================================================
# 设为 1：每次都打开新标签页（不复用）
# ASD_UI_NO_REUSE_TAB=0

# 设为 0：不复用已有标签
# ASD_UI_OPEN_REUSE=1

# =============================================================================
# --- 8. 完整性校验（Native 入口） ---
# =============================================================================
# 开发/调试时跳过 checksums 校验
# ASD_SKIP_CHECKSUMS=1

# =============================================================================
# --- 9. 网络代理（按提供商，可选） ---
# =============================================================================
# ASD_OPENAI_PROXY_HTTP=http://127.0.0.1:7890
# ASD_OPENAI_PROXY_HTTPS=http://127.0.0.1:7890
# ASD_GOOGLE_PROXY_HTTP=http://127.0.0.1:7890
# ASD_GOOGLE_PROXY_HTTPS=http://127.0.0.1:7890
# ASD_DEEPSEEK_PROXY_HTTP=http://127.0.0.1:7890
# ASD_DEEPSEEK_PROXY_HTTPS=http://127.0.0.1:7890
# ASD_CLAUDE_PROXY_HTTP=http://127.0.0.1:7890
# ASD_CLAUDE_PROXY_HTTPS=http://127.0.0.1:7890

# =============================================================================
# --- 10. 飞书 Bot（远程编程桥接） ---
# =============================================================================
# 飞书开放平台 → 自建应用 → 凭证与基础信息
# 用于「手机飞书发消息 → Mac IDE 编程」的长连接桥接
# 配置方式：
#   1. 飞书开放平台创建自建应用，获取 App ID 和 App Secret
#   2. 事件订阅选「使用长连接接收事件」，添加 im.message.receive_v1 事件
#   3. 权限管理中开通 im:message（获取与发送单聊、群聊消息）
#   4. 填入以下两项，启动 asd start 后调用 POST /api/v1/remote/lark/start
ASD_LARK_APP_ID=
ASD_LARK_APP_SECRET=

# 安全白名单：只允许指定飞书用户发送指令（逗号分隔 user_id）
# 不设置则不启用白名单（所有人可发指令）
# 查看 user_id：发一条消息后查数据库 remote_commands 表的 user_id 字段
ASD_LARK_ALLOWED_USERS=

# =============================================================================
# --- 11. 开发与测试（日常使用可忽略） ---
# =============================================================================
# ASD_CWD=                   # CLI 项目根目录覆盖
# ASD_PRESET=                # 预置输入 JSON 路径（自动化/CI）
# ASD_TEST_PRESET=
# ASD_TEST_HOME=             # 测试用模拟项目根目录
# ASD_ACODE_FILE=            # AI 提取时指定源码文件路径
# ASD_TEST_CHANGED_FILES=    # 增量测试变更文件列表
