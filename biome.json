{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": [
      "lib/**",
      "!lib/generated/**",
      "bin/**",
      "config/**",
      "scripts/**",
      "test/**",
      "*.js",
      "*.mjs",
      "*.cjs",
      "*.ts",
      "*.mts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "bracketSpacing": true,
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": [
        "bin/**",
        "scripts/**",
        "lib/cli/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "bin/**",
        "scripts/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noImplicitAnyLet": "off"
          }
        }
      }
    },
    {
      "includes": [
        "lib/resident/tool-schema/types.ts",
        "lib/workflows/capabilities/execution/internal-agent/BootstrapProjections.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedFunctionParameters": "off"
      },
      "complexity": {
        "noThisInStatic": "off",
        "noStaticOnlyClass": "off"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useBlockStatements": "error",
        "useThrowOnlyError": "error"
      },
      "suspicious": {
        "noVar": "error",
        "noDoubleEquals": "error",
        "noExplicitAny": "warn",
        "noImplicitAnyLet": "warn",
        "noAssignInExpressions": "off",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": [
              "warn",
              "error"
            ]
          }
        }
      }
    }
  }
}
